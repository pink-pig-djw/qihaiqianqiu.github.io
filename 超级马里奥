function txt(s,x,y,c,size,align){
  ctx.fillStyle=c||'#fff'; ctx.font=(size||8)+'px "Courier New",monospace';
  ctx.textAlign=align||'left'; ctx.textBaseline='top'; ctx.fillText(s,x,y);
}
function pad(n,w){ n=''+n; while(n.length<w)n='0'+n; return n; }
function drawHUD(){
  txt('MARIO', 16, 6, '#fff', 8);
  txt(pad(score,6), 16, 16, '#fff', 8);
  // coin icon
  ctx.fillStyle='#fac000'; ctx.fillRect(96, 16, 5, 8); ctx.fillStyle='#e09000'; ctx.fillRect(98,17,1,6);
  txt('x'+pad(coins,2), 104, 16, '#fff', 8);
  txt('WORLD', 152, 6, '#fff', 8); txt('1-1', 160, 16, '#fff', 8);
  txt('TIME', 212, 6, '#fff', 8); txt(pad(Math.max(0,Math.ceil(timeLeft)),3), 216, 16, '#fff', 8);
  txt('x'+lives, 60, 16, '#fff', 8); // lives
}

function drawCenterBox(lines, sub){
  ctx.fillStyle='rgba(0,0,0,.55)'; ctx.fillRect(0,0,VW,VH);
  ctx.textAlign='center';
  let y=VH/2 - (lines.length*10)/2 - 12;
  for(const l of lines){ txt(l.t, VW/2, y, l.c||'#fff', l.s||10, 'center'); y+= (l.s||10)+4; }
  if(sub){ txt(sub, VW/2, y+8, '#cfcfe0', 8, 'center'); }
}

function render(){
  ctx.fillStyle='#5c94fc'; ctx.fillRect(0,0,VW,VH);
  drawScenery();
  // tiles in view
  const cStart=Math.max(0, Math.floor(cameraX/TILE)-1);
  const cEnd=Math.min(WIDTH-1, Math.floor((cameraX+VW)/TILE)+1);
  for(let c=cStart;c<=cEnd;c++) for(let r=0;r<ROWS;r++){ const t=grid[r][c]; if(t) drawTile(c,r,t); }
  drawFlag();
  drawCastle();
  drawItems();
  drawEnemies();
  if(!(state==='win'&&winPhase==='done')) drawMario();
  drawFX();
  drawHUD();

  if(state==='title')
    drawCenterBox([
      {t:'SUPER MARIO BROS', c:'#fff', s:14},
      {t:'WORLD  1 - 1', c:'#fac000', s:11}
    ], '按 Enter 或 A键 开始');
  if(state==='gameover')
    drawCenterBox([{t:'GAME OVER', c:'#e04040', s:16}], '按 Enter 重新开始');
  if(state==='win'&&winPhase==='done')
    drawCenterBox([
      {t:'COURSE CLEAR!', c:'#fac000', s:14},
      {t:'分数  '+pad(score,6), c:'#fff', s:10}
    ], '按 Enter 再玩一次');
}

/* ===================== main loop ===================== */
function update(){
  frameNo++;
  if(state==='title'){
    if(enterEdge){ if(!actx){try{actx=new(window.AudioContext||window.webkitAudioContext)();}catch(e){}} resetLevel(true); state='play'; }
    enterEdge=false; return;
  }
  if(state==='gameover'){
    goTimer++;
    if(enterEdge || goTimer>240){ enterEdge=false; resetLevel(true); state='title'; }
    enterEdge=false; return;
  }
  if(state==='win'){
    updateWin(); updateEnemies(); updateItems(); updateFireballs(); updateFX();
    if(winPhase==='done' && enterEdge){ enterEdge=false; resetLevel(true); state='title'; }
    enterEdge=false; return;
  }

  // play / dying
  if(state==='play'){
    timeTick++; if(timeTick>=24){ timeTick=0; timeLeft--; if(timeLeft<=0){ timeLeft=0; die(); } }
  }
  updatePlayer();
  updateEnemies();
  updateItems();
  updateFireballs();
  updateFX();
  enterEdge=false;
}

let last=performance.now(), acc=0; const STEP=1000/60;
function frame(now){
  acc += now-last; last=now;
  if(acc>250) acc=250;
  let n=0;
  while(acc>=STEP && n<5){ update(); acc-=STEP; n++; }
  render();
  requestAnimationFrame(frame);
}
buildLevel();              // build for the title screen background
player=makePlayer(); placeOnGround(player,2);
enemies=[]; items=[]; fireballs=[]; particles=[]; pops=[]; bumps=[];
requestAnimationFrame(frame);
})();
</script>
