function drawMario(){
  const p=player;
  if(p.invuln>0 && state==='play' && (Math.floor(frameNo/4)%2===0)) return; // blink
  const big=p.power>0, W=big?14:12, H=big?28:16, flip=p.dir<0;
  const sets=big?BIG:SMALL;
  let cells;
  if(p.growTimer>0) cells = (Math.floor(frameNo/3)%2)?BIG.idle:SMALL.idle;
  else if(state==='dying') cells = SMALL.jump;
  else if(state==='win' && winPhase!=='slide' && winPhase!=='pause' && Math.abs(p.vx)>0.3) cells=sets.walk[Math.floor(frameNo/6)%2];
  else if(!p.onGround && state==='play') cells=sets.jump;
  else if(p.duck && big) cells=BIG.duck;
  else if(p.skid) cells=sets.skid;
  else if(Math.abs(p.vx)>0.4) cells=sets.walk[Math.floor(p.animTime/8)%2];
  else cells=sets.idle;
  const useH = (p.growTimer>0)?(Math.floor(frameNo/3)%2?28:16):H;
  const useW = (p.growTimer>0)?(Math.floor(frameNo/3)%2?14:12):W;
  const sx=Math.round(p.x + (p.w-useW)/2 - cameraX);
  const sy=Math.round(p.y + p.h - useH);
  drawCells(sx,sy,useW,flip,cells,p.power);
}

