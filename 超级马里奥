// tiles & scenery -------------------------------------------------------------
function drawTile(c,r,t){
  let sx=c*TILE-cameraX, sy=r*TILE + bumpOffset(c,r);
  sx|=0; sy|=0;
  switch(t){
    case T.GROUND: {
      ctx.fillStyle='#c4621e'; ctx.fillRect(sx,sy,16,16);
      ctx.fillStyle='#e2944a'; ctx.fillRect(sx,sy,16,3);
      ctx.fillStyle='#7a3b0e'; ctx.fillRect(sx,sy+15,16,1); ctx.fillRect(sx+15,sy,1,16);
      ctx.fillRect(sx+7,sy+4,2,12); ctx.fillRect(sx,sy+9,16,1);
      break; }
    case T.BRICK: {
      ctx.fillStyle='#c8631e'; ctx.fillRect(sx,sy,16,16);
      ctx.fillStyle='#8a3a0c';
      ctx.fillRect(sx,sy+4,16,1); ctx.fillRect(sx,sy+10,16,1);
      ctx.fillRect(sx+8,sy,1,4); ctx.fillRect(sx+4,sy+5,1,5); ctx.fillRect(sx+12,sy+5,1,5);
      ctx.fillRect(sx+8,sy+11,1,5);
      ctx.fillStyle='#e2944a'; ctx.fillRect(sx,sy,16,1);
      break; }
    case T.QCOIN: case T.QPOW: {
      const blink=(Math.floor(frameNo/12)%3); const base= blink===0?'#f8a800': blink===1?'#fac000':'#e09000';
      ctx.fillStyle=base; ctx.fillRect(sx,sy,16,16);
      ctx.fillStyle='#7a4a00'; ctx.fillRect(sx,sy,16,1); ctx.fillRect(sx,sy+15,16,1); ctx.fillRect(sx,sy,1,16); ctx.fillRect(sx+15,sy,1,16);
      ctx.fillStyle='#7a4a00'; [[2,2],[12,2],[2,12],[12,12]].forEach(p=>ctx.fillRect(sx+p[0],sy+p[1],2,2));
      ctx.fillStyle='#fff'; ctx.font='bold 11px "Courier New",monospace'; ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText('?', sx+8, sy+9);
      break; }
    case T.USED: {
      ctx.fillStyle='#9a6a30'; ctx.fillRect(sx,sy,16,16);
      ctx.fillStyle='#6a4418'; ctx.fillRect(sx,sy,16,1); ctx.fillRect(sx,sy+15,16,1); ctx.fillRect(sx,sy,1,16); ctx.fillRect(sx+15,sy,1,16);
      [[2,2],[12,2],[2,12],[12,12]].forEach(p=>ctx.fillRect(sx+p[0],sy+p[1],2,2));
      break; }
    case T.PIPETL: case T.PIPETR: {
      const lip = t===T.PIPETL;
      const x = lip? sx-2 : sx;
      ctx.fillStyle='#2ca02c'; ctx.fillRect(x, sy, 18, 16);
      ctx.fillStyle='#7ad07a'; ctx.fillRect(x, sy, 4, 16);
      ctx.fillStyle='#1f7a1f'; ctx.fillRect(x+14, sy, 4, 16);
      ctx.fillStyle='#0f5a0f'; ctx.fillRect(x, sy+5, 18, 1);
      // inner body alignment line
      ctx.fillStyle='#1f7a1f'; ctx.fillRect(sx + (lip?1:-1), sy+6, 16, 0);
      break; }
    case T.PIPEBL: case T.PIPEBR: {
      const isL = t===T.PIPEBL;
      ctx.fillStyle='#2ca02c'; ctx.fillRect(sx,sy,16,16);
      ctx.fillStyle= isL?'#7ad07a':'#2ca02c'; if(isL) ctx.fillRect(sx,sy,4,16);
      ctx.fillStyle='#1f7a1f'; if(!isL) ctx.fillRect(sx+12,sy,4,16);
      break; }
    case T.COIN: {
      const ph=Math.floor(frameNo/8)%4, ww=[9,5,2,5][ph];
      ctx.fillStyle='#fac000'; ctx.fillRect(sx+(16-ww)/2|0, sy+2, ww, 12);
      ctx.fillStyle='#e09000'; if(ww>3) ctx.fillRect(sx+8|0, sy+3, 1, 10);
      break; }
  }
}
