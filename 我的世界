const solidAt=(x,y,z)=>isSolidBlock(getBlock(x,y,z));
function aabbHitsVoxel(minx,miny,minz,maxx,maxy,maxz,vx,vy,vz){
  return minx<vx+1&&maxx>vx&&miny<vy+1&&maxy>vy&&minz<vz+1&&maxz>vz; }
function moveAxis(axis,d){
  const w=player.width/2,h=player.height,p=player.pos; p[axis]+=d;
  let minx=p.x-w,maxx=p.x+w,miny=p.y,maxy=p.y+h,minz=p.z-w,maxz=p.z+w;
  const x0=Math.floor(minx),x1=Math.floor(maxx),y0=Math.floor(miny),y1=Math.floor(maxy),z0=Math.floor(minz),z1=Math.floor(maxz);
  let collided=false;
  for(let x=x0;x<=x1;x++)for(let y=y0;y<=y1;y++)for(let z=z0;z<=z1;z++){
    if(!solidAt(x,y,z))continue;
    if(!aabbHitsVoxel(minx,miny,minz,maxx,maxy,maxz,x,y,z))continue;
    collided=true;
    if(axis==="x"){ if(d>0)p.x=Math.min(p.x,x-w-EPS); else p.x=Math.max(p.x,x+1+w+EPS); minx=p.x-w;maxx=p.x+w; }
    else if(axis==="y"){ if(d>0)p.y=Math.min(p.y,y-h-EPS); else p.y=Math.max(p.y,y+1+EPS); miny=p.y;maxy=p.y+h; }
    else { if(d>0)p.z=Math.min(p.z,z-w-EPS); else p.z=Math.max(p.z,z+1+w+EPS); minz=p.z-w;maxz=p.z+w; }
  }
  if(collided){ if(axis==="y"&&d<0)player.onGround=true; player.vel[axis]=0; }
}

function updatePhysics(dt){
  const sin=Math.sin(yaw),cos=Math.cos(yaw);
  let fwd=0,str=0;
  if(keys["KeyW"])fwd+=1; if(keys["KeyS"])fwd-=1; if(keys["KeyD"])str+=1; if(keys["KeyA"])str-=1;
  fwd += -moveVec.y; str += moveVec.x;   // 触摸摇杆
  let dx=0,dz=0;
  if(fwd||str){ dx=(-sin*fwd)+(cos*str); dz=(-cos*fwd)+(-sin*str); const l=Math.hypot(dx,dz); dx/=l;dz/=l; }

  const fx=Math.floor(player.pos.x),fz=Math.floor(player.pos.z);
  inWater = getBlock(fx,Math.floor(player.pos.y+0.9),fz)===WATER || getBlock(fx,Math.floor(player.pos.y+0.2),fz)===WATER;
  document.body.classList.toggle("underwater", inWater);

  const sprint=(keys["ShiftLeft"]||keys["ShiftRight"]);
  const speed=(sprint?SPRINT:WALK)*(inWater?0.62:1);
  player.vel.x=dx*speed; player.vel.z=dz*speed;

  if(inWater){
    player.vel.y-=GRAV*0.30*dt; player.vel.y*=Math.pow(0.80,dt*60);
    if(player.vel.y<-6)player.vel.y=-6;
    if(keys["Space"]||touchJump)player.vel.y=3.6;
  } else {
    player.vel.y-=GRAV*dt; if(player.vel.y<-MAXFALL)player.vel.y=-MAXFALL;
    if((keys["Space"]||touchJump)&&player.onGround){player.vel.y=JUMP;player.onGround=false;sfxJump();}
  }
  player.lastFallVel=player.vel.y;
  player.onGround=false;
  // 子步进：把一帧位移拆成 <=0.4 格的小步，逐步碰撞，杜绝高速穿模
  let mvx=player.vel.x*dt, mvy=player.vel.y*dt, mvz=player.vel.z*dt;
  const steps=Math.max(1, Math.ceil(Math.max(Math.abs(mvx),Math.abs(mvy),Math.abs(mvz))/0.4));
  const sx=mvx/steps, sy=mvy/steps, sz=mvz/steps;
  for(let i=0;i<steps;i++){ moveAxis("y",sy); moveAxis("x",sx); moveAxis("z",sz); }
  if(player.pos.y<-8) spawnPlayer();
  camera.position.set(player.pos.x,player.pos.y+player.eye,player.pos.z);
  camera.rotation.set(pitch,yaw,0,"YXZ");
}

