<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>我的世界 · 网页还原版</title>
<style>
  :root{
    --hud:#f4f4f4; --hud-shadow:rgba(0,0,0,.55);
    --slot:rgba(20,20,24,.55); --slot-edge:rgba(255,255,255,.18); --sel:#ffffff;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html,body{height:100%;overflow:hidden;background:#000;
    font-family:"Trebuchet MS","Segoe UI",system-ui,sans-serif;
    -webkit-user-select:none;user-select:none;cursor:default;}
  #game{position:fixed;inset:0;display:block;}

  /* 水下滤镜 */
  #water-overlay{position:fixed;inset:0;z-index:4;pointer-events:none;
    background:rgba(30,96,180,.34);opacity:0;transition:opacity .25s;}
  body.underwater #water-overlay{opacity:1;}

  /* 准星 */
  #crosshair{position:fixed;left:50%;top:50%;width:22px;height:22px;
    transform:translate(-50%,-50%);pointer-events:none;z-index:6;
    opacity:0;transition:opacity .2s;mix-blend-mode:difference;}
  #crosshair::before,#crosshair::after{content:"";position:absolute;background:#fff;}
  #crosshair::before{left:50%;top:0;width:2px;height:100%;transform:translateX(-50%);}
  #crosshair::after{top:50%;left:0;height:2px;width:100%;transform:translateY(-50%);}
  body.playing #crosshair{opacity:.9;}
  #mine-ring{position:fixed;left:50%;top:50%;width:34px;height:34px;transform:translate(-50%,-50%);
    border-radius:50%;opacity:0;pointer-events:none;z-index:6;
    -webkit-mask:radial-gradient(circle, transparent 9px, #000 10px);
            mask:radial-gradient(circle, transparent 9px, #000 10px);}

  /* 物品栏 */
  #hotbar{position:fixed;left:50%;bottom:18px;transform:translateX(-50%);
    display:flex;gap:5px;padding:6px;border-radius:8px;
    background:rgba(0,0,0,.30);backdrop-filter:blur(2px);z-index:6;
    opacity:0;transition:opacity .25s;}
  body.playing #hotbar{opacity:1;}
  .slot{position:relative;width:46px;height:46px;border-radius:6px;
    background:var(--slot);border:2px solid var(--slot-edge);
    display:flex;align-items:center;justify-content:center;}
  .slot canvas{width:34px;height:34px;image-rendering:pixelated;}
  .slot .key{position:absolute;top:-1px;left:3px;font-size:10.5px;color:#cfcfcf;text-shadow:1px 1px 0 #000;}
  .slot.sel{border-color:var(--sel);box-shadow:0 0 0 2px rgba(255,255,255,.25),0 0 14px rgba(255,255,255,.25);}
  .slot .name{position:absolute;bottom:-20px;left:50%;transform:translateX(-50%);
    white-space:nowrap;font-size:12px;color:var(--hud);text-shadow:1px 1px 0 #000;opacity:0;transition:opacity .2s;}
  .slot.sel .name{opacity:1;}

  /* 信息 HUD */
  #hud{position:fixed;left:12px;top:10px;z-index:6;color:var(--hud);
    font-size:12.5px;line-height:1.55;text-shadow:1px 1px 0 var(--hud-shadow);
    opacity:0;transition:opacity .25s;pointer-events:none;}
  body.playing #hud{opacity:.88;}
  #hud b{color:#9fe07a;font-weight:600;}
  #clock{position:fixed;right:12px;top:10px;z-index:6;color:var(--hud);
    font-size:13px;text-shadow:1px 1px 0 var(--hud-shadow);opacity:0;transition:opacity .25s;
    display:flex;align-items:center;gap:7px;pointer-events:none;}
  body.playing #clock{opacity:.9;}
  #clock .orb{width:13px;height:13px;border-radius:50%;box-shadow:0 0 8px rgba(255,255,255,.4);}

  /* 开始遮罩 */
  #overlay{position:fixed;inset:0;z-index:20;display:flex;flex-direction:column;
    align-items:center;justify-content:center;text-align:center;color:#fff;
    background:radial-gradient(120% 120% at 50% 30%, rgba(20,26,40,.55), rgba(6,8,14,.9));
    backdrop-filter:blur(3px);transition:opacity .3s;cursor:pointer;}
  #overlay.hide{opacity:0;pointer-events:none;}
  .logo{font-size:clamp(34px,7vw,68px);font-weight:800;letter-spacing:2px;line-height:1;margin-bottom:6px;
    text-shadow:0 3px 0 #1f6b1f,0 4px 0 #155015,0 6px 18px rgba(0,0,0,.6);}
  .logo span{color:#7fd35a;}
  .sub{font-size:14px;color:#b9c2cf;margin-bottom:24px;letter-spacing:1px;}
  .play{font-size:15px;font-weight:700;color:#0d0d0d;background:#7fd35a;padding:12px 26px;border-radius:8px;
    box-shadow:0 4px 0 #4f9a35,0 8px 20px rgba(0,0,0,.4);transition:transform .08s, box-shadow .08s;}
  #overlay:hover .play{transform:translateY(2px);box-shadow:0 2px 0 #4f9a35,0 6px 16px rgba(0,0,0,.4);}
  .keys{margin-top:28px;display:grid;grid-template-columns:auto auto;gap:6px 22px;
    font-size:12.5px;color:#cfd6df;text-align:left;}
  .keys kbd{display:inline-block;min-width:18px;padding:1px 6px;margin-right:6px;
    background:#23262e;border:1px solid #3a3f4a;border-bottom-width:2px;border-radius:4px;
    font-family:inherit;font-size:11px;color:#fff;text-align:center;}
  .tag{position:fixed;bottom:10px;right:12px;font-size:11px;color:#586173;z-index:21;}
  #loading{position:fixed;inset:0;z-index:30;display:flex;align-items:center;justify-content:center;
    background:#0a0d14;color:#9fe07a;font-size:15px;letter-spacing:2px;}
  /* ===== 移动端触控 ===== */
  html,body{touch-action:none;overscroll-behavior:none;-webkit-touch-callout:none;-webkit-tap-highlight-color:transparent;}
  #touch-controls{position:fixed;inset:0;z-index:5;display:none;}
  body.touch.playing #touch-controls{display:block;}
  #move-zone,#look-zone{position:absolute;top:0;bottom:0;touch-action:none;}
  #move-zone{left:0;width:48%;}
  #look-zone{right:0;width:52%;}
  #joystick{position:absolute;width:120px;height:120px;border-radius:50%;
    background:rgba(255,255,255,.10);border:2px solid rgba(255,255,255,.28);
    opacity:0;transition:opacity .12s;pointer-events:none;}
  #joy-knob{position:absolute;left:33px;top:33px;width:54px;height:54px;border-radius:50%;
    background:rgba(255,255,255,.32);border:2px solid rgba(255,255,255,.55);box-shadow:0 2px 10px rgba(0,0,0,.4);}
  .tbtn{position:absolute;border-radius:50%;display:flex;align-items:center;justify-content:center;
    background:rgba(20,22,28,.46);border:2px solid rgba(255,255,255,.32);color:#fff;
    font-size:16px;font-weight:700;text-shadow:1px 1px 0 rgba(0,0,0,.5);
    touch-action:none;user-select:none;z-index:8;backdrop-filter:blur(2px);}
  .tbtn.pressed{background:rgba(127,211,90,.5);border-color:#fff;transform:scale(.94);}
  #btn-break{right:20px;bottom:80px;width:74px;height:74px;font-size:17px;}
  #btn-place{right:104px;bottom:96px;width:60px;height:60px;}
  #btn-jump{right:30px;bottom:168px;width:60px;height:60px;}
  #pause-btn{position:fixed;left:12px;top:8px;width:38px;height:38px;border-radius:8px;z-index:9;
    display:none;align-items:center;justify-content:center;color:#fff;font-size:15px;
    background:rgba(20,22,28,.5);border:1px solid rgba(255,255,255,.25);}
  body.touch.playing #pause-btn{display:flex;}
  #sound-btn{position:fixed;left:58px;top:8px;width:38px;height:38px;border-radius:8px;z-index:9;
    display:none;align-items:center;justify-content:center;font-size:16px;
    background:rgba(20,22,28,.5);border:1px solid rgba(255,255,255,.25);}
  body.touch.playing #sound-btn{display:flex;}

  body.touch #hud{top:50px;}
  body.touch .tag{display:none;}
  .touchhelp{display:none;margin-top:24px;font-size:13px;color:#cfd6df;line-height:1.7;}
  body.touch .keys{display:none;}
  body.touch .touchhelp{display:block;}

  @media (max-width:560px){
    body.touch .slot{width:32px;height:32px;border-radius:5px;}
    body.touch .slot canvas{width:24px;height:24px;}
    body.touch #hotbar{gap:3px;padding:4px;bottom:12px;}
    body.touch .slot .key{font-size:9px;}
    body.touch .slot .name{display:none;}
  }
  @media (max-width:380px){
    body.touch .slot{width:28px;height:28px;}
    body.touch .slot canvas{width:21px;height:21px;}
    body.touch #hotbar{gap:2px;}
  }
</style>
</head>
<body>
  <canvas id="game"></canvas>
  <div id="water-overlay"></div>
  <div id="crosshair"></div>
  <div id="mine-ring"></div>
  <div id="hud"></div>
  <div id="clock"></div>
  <div id="hotbar"></div>

  <div id="loading">正在生成世界…</div>

  <div id="overlay">
    <div class="logo">我的<span>世界</span></div>
    <div class="sub">网页从零还原版 · 生物群系 / 昼夜交替</div>
    <div class="play">点击进入世界</div>
    <div class="keys">
      <div><kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd> 移动</div>
      <div><kbd>左键</kbd> 破坏方块</div>
      <div><kbd>空格</kbd> 跳跃 / 游上</div>
      <div><kbd>右键</kbd> 放置方块</div>
      <div><kbd>Shift</kbd> 加速奔跑</div>
      <div><kbd>1</kbd>–<kbd>0</kbd> / 滚轮 选择方块</div>
      <div><kbd>T</kbd> 按住加速时间</div>
      <div><kbd>M</kbd> 静音 / 恢复</div>
      <div><kbd>Esc</kbd> 释放鼠标</div>
    </div>
    <div class="touchhelp">
      左半屏拖动 — 移动行走 &nbsp;·&nbsp; 右半屏拖动 — 转动视角<br>
      右下按钮 — 挖掘 / 放置 / 跳跃 &nbsp;·&nbsp; 点物品栏切换方块<br>
      左上 ❚❚ 暂停 &nbsp;·&nbsp; 落水后跳跃键可上浮
    </div>
  </div>
  <div class="tag">点击画面锁定鼠标 · 再次点击破坏/放置</div>

  <!-- 移动端触控层 -->
  <div id="touch-controls">
    <div id="move-zone"></div>
    <div id="look-zone"></div>
    <div id="joystick"><div id="joy-knob"></div></div>
    <div id="btn-jump" class="tbtn">跳</div>
    <div id="btn-place" class="tbtn">放</div>
    <div id="btn-break" class="tbtn">挖</div>
  </div>
  <div id="pause-btn">❚❚</div>
  <div id="sound-btn">🔊</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
"use strict";
/* =========================================================================
   我的世界 · 从零还原（增强版）
   新增：生物群系地形 / 海洋 + 游泳 / 洞穴(3D 噪声) / 矿石 /
        生物群系树木 + 十字形花草 / 昼夜交替（渐变天空·日月·星空·光照）
   ========================================================================= */

/* ----------------------------- 常量 ------------------------------ */
const isTouch = (window.matchMedia ? window.matchMedia("(pointer: coarse)").matches
                                   : (("ontouchstart" in window) || navigator.maxTouchPoints>0));
const CHUNK=16, EPS=1e-3;
const WX = isTouch?160:256, WY=64, WZ = WX;     // 方形世界（移动端更小）
const RENDER_DIST = isTouch?4:6;                // 渲染距离（区块）
const BASE_H=12, SEA=9, SNOW_LINE=22;

// 方块 id
const AIR=0, GRASS=1, DIRT=2, STONE=3, COBBLE=4, WOOD=5, LEAVES=6, SAND=7, PLANK=8, GLASS=9, BRICK=10,
      WATER=11, SNOW=12, CACTUS=13, ORE_COAL=14, ORE_IRON=15, ORE_GOLD=16, ORE_DIAMOND=17,
      SPRUCE_LOG=18, SPRUCE_LEAVES=19, FLOWER_RED=20, FLOWER_YELLOW=21, TALLGRASS=22,
      ICE=23, GRAVEL=24, BIRCH_LOG=25, BIRCH_LEAVES=26, PUMPKIN=27, DEAD_BUSH=28, FLOWER_BLUE=29;

const TRANSPARENT = new Set([LEAVES, GLASS, WATER, SPRUCE_LEAVES, ICE, BIRCH_LEAVES]); // 整块透明
const CROSS = new Set([FLOWER_RED, FLOWER_YELLOW, FLOWER_BLUE, TALLGRASS, DEAD_BUSH]); // 十字植物
const FALLING = new Set([SAND, GRAVEL]);                            // 受重力下落
const isOpaque = t => t!==AIR && !TRANSPARENT.has(t) && !CROSS.has(t);
const isSolidBlock = t => t!==AIR && t!==WATER && !CROSS.has(t);    // 参与碰撞

// 挖掘硬度（秒）
const HARD_DEFAULT=0.4;
const HARDNESS = {
  [DIRT]:0.25,[GRASS]:0.3,[SAND]:0.3,[GRAVEL]:0.4,[SNOW]:0.2,[LEAVES]:0.1,[SPRUCE_LEAVES]:0.1,[BIRCH_LEAVES]:0.1,
  [WOOD]:0.7,[PLANK]:0.6,[SPRUCE_LOG]:0.7,[BIRCH_LOG]:0.7,[GLASS]:0.2,[ICE]:0.45,[CACTUS]:0.3,[PUMPKIN]:0.5,
  [STONE]:1.2,[COBBLE]:1.3,[BRICK]:1.3,[ORE_COAL]:1.5,[ORE_IRON]:1.7,[ORE_GOLD]:1.7,[ORE_DIAMOND]:2.0,
  [FLOWER_RED]:0.05,[FLOWER_YELLOW]:0.05,[FLOWER_BLUE]:0.05,[TALLGRASS]:0.05,[DEAD_BUSH]:0.05
};
const hardnessOf = t => HARDNESS[t]!==undefined?HARDNESS[t]:HARD_DEFAULT;

// 生物群系
const PLAINS=0, FOREST=1, DESERT=2, SNOWY=3, MOUNTAIN=4;
const BIOME_NAME=["平原","森林","沙漠","雪原","山地"];

/* 贴图集 tile 索引 */
const T = {
  grass_top:0, grass_side:1, dirt:2, stone:3, cobble:4, wood_top:5, wood_side:6, leaves:7,
  sand:8, plank:9, brick:10, glass:11, water:12, snow:13, cactus_top:14, cactus_side:15,
  coal:16, iron:17, gold:18, diamond:19, spruce_side:20, spruce_leaves:21,
  flower_red:22, flower_yellow:23, tallgrass:24,
  ice:25, gravel:26, birch_side:27, birch_leaves:28, pumpkin_top:29, pumpkin_side:30, pumpkin_front:31,
  dead_bush:32, flower_blue:33
};
const TILE_COUNT = 34;

function fill6(t){return [t,t,t,t,t,t];}
/* 每方块 6 面 tile：[+X,-X,+Y上,-Y下,+Z,-Z] */
const BLOCK_TILES = {
  [GRASS]:[T.grass_side,T.grass_side,T.grass_top,T.dirt,T.grass_side,T.grass_side],
  [DIRT]:fill6(T.dirt), [STONE]:fill6(T.stone), [COBBLE]:fill6(T.cobble),
  [WOOD]:[T.wood_side,T.wood_side,T.wood_top,T.wood_top,T.wood_side,T.wood_side],
  [LEAVES]:fill6(T.leaves), [SAND]:fill6(T.sand), [PLANK]:fill6(T.plank),
  [GLASS]:fill6(T.glass), [BRICK]:fill6(T.brick), [WATER]:fill6(T.water), [SNOW]:fill6(T.snow),
  [CACTUS]:[T.cactus_side,T.cactus_side,T.cactus_top,T.cactus_top,T.cactus_side,T.cactus_side],
  [ORE_COAL]:fill6(T.coal), [ORE_IRON]:fill6(T.iron), [ORE_GOLD]:fill6(T.gold), [ORE_DIAMOND]:fill6(T.diamond),
  [SPRUCE_LOG]:[T.spruce_side,T.spruce_side,T.wood_top,T.wood_top,T.spruce_side,T.spruce_side],
  [SPRUCE_LEAVES]:fill6(T.spruce_leaves),
  [ICE]:fill6(T.ice), [GRAVEL]:fill6(T.gravel),
  [BIRCH_LOG]:[T.birch_side,T.birch_side,T.wood_top,T.wood_top,T.birch_side,T.birch_side],
  [BIRCH_LEAVES]:fill6(T.birch_leaves),
  [PUMPKIN]:[T.pumpkin_side,T.pumpkin_side,T.pumpkin_top,T.pumpkin_top,T.pumpkin_front,T.pumpkin_side],
};
const CROSS_TILE = { [FLOWER_RED]:T.flower_red, [FLOWER_YELLOW]:T.flower_yellow, [FLOWER_BLUE]:T.flower_blue,
  [TALLGRASS]:T.tallgrass, [DEAD_BUSH]:T.dead_bush };

/* 物品栏（1-9,0 + 滚轮翻到更多） */
const HOTBAR = [
  {id:GRASS,name:"草方块"},{id:DIRT,name:"泥土"},{id:STONE,name:"石头"},{id:COBBLE,name:"圆石"},
  {id:WOOD,name:"木头"},{id:PLANK,name:"木板"},{id:LEAVES,name:"树叶"},{id:GLASS,name:"玻璃"},
  {id:SAND,name:"沙子"},{id:SNOW,name:"雪块"},{id:ICE,name:"冰块"},{id:GRAVEL,name:"砂砾"}
];

/* ----------------------------- 世界数据 ------------------------------ */
const voxels = new Uint8Array(WX*WY*WZ);
const idx=(x,y,z)=>x+WX*(z+WZ*y);
const inBounds=(x,y,z)=>x>=0&&x<WX&&y>=0&&y<WY&&z>=0&&z<WZ;
const getBlock=(x,y,z)=>inBounds(x,y,z)?voxels[idx(x,y,z)]:AIR;
const setRaw=(x,y,z,t)=>{ if(inBounds(x,y,z)) voxels[idx(x,y,z)]=t; };

/* ----------------------------- 噪声 ------------------------------ */
const perm=new Uint8Array(512);
(function(seed){const p=new Uint8Array(256);for(let i=0;i<256;i++)p[i]=i;let s=seed>>>0;
  const rnd=()=>{s=(Math.imul(s,1664525)+1013904223)>>>0;return s/4294967296;};
  for(let i=255;i>0;i--){const j=(rnd()*(i+1))|0;const t=p[i];p[i]=p[j];p[j]=t;}
  for(let i=0;i<512;i++)perm[i]=p[i&255];})(20260621);
const fade=t=>t*t*t*(t*(t*6-15)+10), lrp=(a,b,t)=>a+(b-a)*t;
function grad2(h,x,y){const u=(h&1)?x:-x,v=(h&2)?y:-y;return u+v;}
function perlin2(x,y){
  const X=Math.floor(x)&255,Y=Math.floor(y)&255; x-=Math.floor(x); y-=Math.floor(y);
  const u=fade(x),v=fade(y);
  const aa=perm[perm[X]+Y],ab=perm[perm[X]+Y+1],ba=perm[perm[X+1]+Y],bb=perm[perm[X+1]+Y+1];
  return lrp(lrp(grad2(aa,x,y),grad2(ba,x-1,y),u),lrp(grad2(ab,x,y-1),grad2(bb,x-1,y-1),u),v);
}
function fractal(x,y){let amp=1,freq=1,sum=0,norm=0;for(let o=0;o<4;o++){sum+=perlin2(x*freq,y*freq)*amp;norm+=amp;amp*=0.5;freq*=2;}return sum/norm;}
function grad3(h,x,y,z){h&=15;const u=h<8?x:y;const v=h<4?y:(h===12||h===14?x:z);return ((h&1)?-u:u)+((h&2)?-v:v);}
function perlin3(x,y,z){
  const X=Math.floor(x)&255,Y=Math.floor(y)&255,Z=Math.floor(z)&255;
  x-=Math.floor(x);y-=Math.floor(y);z-=Math.floor(z);
  const u=fade(x),v=fade(y),w=fade(z);
  const A=perm[X]+Y,AA=perm[A]+Z,AB=perm[A+1]+Z,B=perm[X+1]+Y,BA=perm[B]+Z,BB=perm[B+1]+Z;
  return lrp(
    lrp(lrp(grad3(perm[AA],x,y,z),grad3(perm[BA],x-1,y,z),u),lrp(grad3(perm[AB],x,y-1,z),grad3(perm[BB],x-1,y-1,z),u),v),
    lrp(lrp(grad3(perm[AA+1],x,y,z-1),grad3(perm[BA+1],x-1,y,z-1),u),lrp(grad3(perm[AB+1],x,y-1,z-1),grad3(perm[BB+1],x-1,y-1,z-1),u),v),
    w);
}
function hash3(x,y,z){ let h=Math.imul(x|0,374761393)^Math.imul(y|0,668265263)^Math.imul(z|0,2147483647);
  h=Math.imul(h^(h>>>13),1274126177); return ((h^(h>>>16))>>>0)/4294967296; }

/* ----------------------------- 地形 / 生物群系 ------------------------------ */
function columnInfo(x,z){
  const e=fractal(x*0.045+11.5, z*0.045+19.5);     // 基础起伏
  const m0=fractal(x*0.016+301.5, z*0.016+121.5);   // 山脉
  const tp=fractal(x*0.020+701.5, z*0.020+541.5);    // 温度
  const mo=fractal(x*0.022+911.5, z*0.022+1300.5);  // 湿度
  const mountain=Math.max(0, m0);
  let h=Math.floor(BASE_H + e*10 + mountain*mountain*58);
  if(h<3)h=3; if(h>WY-6)h=WY-6;
  const topY=h-1;
  let biome;
  if(topY>=SNOW_LINE || tp<-0.18) biome=SNOWY;
  else if(tp>0.20 && mountain<0.18 && topY>SEA) biome=DESERT;
  else if(mountain>0.28) biome=MOUNTAIN;
  else if(mo>0.03 && tp>-0.12) biome=FOREST;
  else biome=PLAINS;
  return {h, topY, biome, mountain, temp:tp};
}

function genWorld(){
  for(let z=0;z<WZ;z++) for(let x=0;x<WX;x++){
    const info = columnInfo(x,z);
    const h=info.h, topY=info.topY, biome=info.biome;

    // 表层方块
    let topB, subB;
    if(biome===DESERT){ topB=SAND; subB=SAND; }
    else if(biome===SNOWY){ topB=SNOW; subB=DIRT; }
    else if(biome===MOUNTAIN){ const rock=topY>18; topB=rock?STONE:GRASS; subB=rock?STONE:DIRT;
      if(rock && hash3((x/3)|0,5,(z/3)|0)<0.22) topB=GRAVEL; }
    else { topB=GRASS; subB=DIRT; }
    if(topY<=SEA+1 && biome!==DESERT && biome!==SNOWY){ topB=SAND; subB=SAND; } // 水边/水下沙滩

    // 填充
    for(let y=0;y<h;y++){
      let t;
      if(y===0) t=STONE;
      else if(y===topY) t=topB;
      else if(y>topY-4) t=subB;
      else t=STONE;
      setRaw(x,y,z,t);
    }
    // 洞穴（仅挖石头，留住地表泥层做顶）
    for(let y=2;y<topY-1;y++){
      if(getBlock(x,y,z)!==STONE) continue;
      const c=perlin3(x*0.085+5.5, y*0.13+9.5, z*0.085+2.5);
      if(c>0.48) setRaw(x,y,z,AIR);
    }
    // 矿石
    for(let y=1;y<topY-1;y++){
      if(getBlock(x,y,z)!==STONE) continue;
      const rd=hash3(x+13,y-91,z+41), rg=hash3(x-31,y+57,z+19), ri=hash3(x+91,y+7,z-13), rc=hash3(x,y,z);
      let t=0;
      if(y<=6 && rd<0.0016) t=ORE_DIAMOND;
      else if(y<=11 && rg<0.004) t=ORE_GOLD;
      else if(y<=22 && ri<0.010) t=ORE_IRON;
      else if(rc<0.018) t=ORE_COAL;
      if(t) setRaw(x,y,z,t);
    }
    // 注水（雪原湖面结冰）
    if(topY<SEA){ for(let y=h;y<=SEA;y++){ if(getBlock(x,y,z)===AIR) setRaw(x,y,z,WATER); }
      if(biome===SNOWY) setRaw(x,SEA,z,ICE); }

    // 植被（只在地表上方空气格）
    if(getBlock(x,h,z)===AIR && x>2 && x<WX-3 && z>2 && z<WZ-3){
      const r=hash3(x,777,z), rb=hash3(x+5,778,z-5);
      if(biome===DESERT){ if(r<0.020) plantCactus(x,h,z); else if(r<0.060) setRaw(x,h,z,DEAD_BUSH); }
      else if(biome===SNOWY){ if(topB!==SAND && r<0.028) plantSpruce(x,h,z); }
      else if(biome===MOUNTAIN){ if(topB===GRASS && r<0.012) plantSpruce(x,h,z); }
      else if(biome===FOREST){ if(topB===GRASS){ if(r<0.090){ if(rb<0.35) plantBirch(x,h,z); else plantOak(x,h,z); } else decorate(x,h,z,true); } }
      else { if(topB===GRASS){ if(r<0.014){ if(rb<0.25) plantBirch(x,h,z); else plantOak(x,h,z); } else decorate(x,h,z,true); } }
    }
  }
}
function decorate(x,h,z,flowers){
  if(getBlock(x,h,z)!==AIR) return;
  const r=hash3(x,222,z);
  if(r<0.34) setRaw(x,h,z,TALLGRASS);
  else if(flowers && r<0.355) setRaw(x,h,z,FLOWER_RED);
  else if(flowers && r<0.370) setRaw(x,h,z,FLOWER_YELLOW);
  else if(flowers && r<0.385) setRaw(x,h,z,FLOWER_BLUE);
  else if(r>0.992) setRaw(x,h,z,PUMPKIN);
}
function plantOak(x,h,z){
  const th=4+((hash3(x+7,1,z+3)*2)|0);
  const topTrunk=h+th-1; if(topTrunk+2>=WY) return;
  for(let y=h;y<h+th;y++) setRaw(x,y,z,WOOD);
  for(let dy=-1;dy<=1;dy++){ const r=dy<1?2:1, ly=topTrunk+dy+1;
    for(let dx=-r;dx<=r;dx++) for(let dz=-r;dz<=r;dz++){
      if(Math.abs(dx)===r&&Math.abs(dz)===r&&dy===1) continue;
      if(dx===0&&dz===0&&dy<1) continue;
      if(getBlock(x+dx,ly,z+dz)===AIR) setRaw(x+dx,ly,z+dz,LEAVES);
    } }
  setRaw(x,topTrunk+2,z,LEAVES);
}
function plantSpruce(x,h,z){
  const th=5+((hash3(x+5,2,z+9)*3)|0); const top=h+th; if(top+1>=WY) return;
  for(let y=h;y<h+th;y++) setRaw(x,y,z,SPRUCE_LOG);
  for(let ly=h+1; ly<=top; ly++){
    const r=Math.min(2, Math.floor((top-ly)/2));
    for(let dx=-r;dx<=r;dx++) for(let dz=-r;dz<=r;dz++){
      if(Math.abs(dx)+Math.abs(dz)>r+1) continue;
      if(getBlock(x+dx,ly,z+dz)===AIR) setRaw(x+dx,ly,z+dz,SPRUCE_LEAVES);
    }
  }
  setRaw(x,top+1,z,SPRUCE_LEAVES);
}
function plantBirch(x,h,z){
  const th=5+((hash3(x+2,4,z+8)*3)|0);
  const topTrunk=h+th-1; if(topTrunk+2>=WY) return;
  for(let y=h;y<h+th;y++) setRaw(x,y,z,BIRCH_LOG);
  for(let dy=-1;dy<=1;dy++){ const r=dy<1?2:1, ly=topTrunk+dy+1;
    for(let dx=-r;dx<=r;dx++) for(let dz=-r;dz<=r;dz++){
      if(Math.abs(dx)===r&&Math.abs(dz)===r&&dy===1) continue;
      if(dx===0&&dz===0&&dy<1) continue;
      if(getBlock(x+dx,ly,z+dz)===AIR) setRaw(x+dx,ly,z+dz,BIRCH_LEAVES);
    } }
  setRaw(x,topTrunk+2,z,BIRCH_LEAVES);
}
function plantCactus(x,h,z){
  const ch=1+((hash3(x+3,3,z+7)*3)|0); if(h+ch>=WY) return;
  for(let y=h;y<h+ch;y++) setRaw(x,y,z,CACTUS);
}

