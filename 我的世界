            const o2=isOpaque(getBlock(x+ao.s2[0],y+ao.s2[1],z+ao.s2[2]))?1:0;
            const oc=isOpaque(getBlock(x+ao.cc[0],y+ao.cc[1],z+ao.cc[2]))?1:0;
            v=sh*AO_MUL[(o1&&o2)?0:(3-(o1+o2+oc))]; }
