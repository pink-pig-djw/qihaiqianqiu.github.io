function emitCross(P,C,U,I,x,y,z,tile){
  const uv=tileUV(tile);
  const uvc=[[uv.u0,uv.v1],[uv.u1,uv.v1],[uv.u1,uv.v0],[uv.u0,uv.v0]], sh=0.95;
  const quads=[
    [[x,y,z],[x+1,y,z+1],[x+1,y+1,z+1],[x,y+1,z]],
    [[x,y,z+1],[x+1,y,z],[x+1,y+1,z],[x,y+1,z+1]],
