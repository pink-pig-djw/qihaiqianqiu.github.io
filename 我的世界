/* ----------------------------- 音效 / 音乐（Web Audio 合成） ------------------------------ */
let actx=null, masterGain, musicGain, sfxGain, noiseBuf=null, muted=false, musicTimer=null;
function initAudio(){
  if(actx){ if(actx.state==="suspended") actx.resume(); return; }
  try{ actx=new (window.AudioContext||window.webkitAudioContext)(); }catch(e){ return; }
  masterGain=actx.createGain(); masterGain.gain.value=muted?0.0001:0.9; masterGain.connect(actx.destination);
  musicGain =actx.createGain(); musicGain.gain.value=0.0001; musicGain.connect(masterGain);
  sfxGain   =actx.createGain(); sfxGain.gain.value=0.7; sfxGain.connect(masterGain);
  startMusic();
}
function getNoise(){ if(noiseBuf)return noiseBuf; const n=(actx.sampleRate*0.4)|0;
  noiseBuf=actx.createBuffer(1,n,actx.sampleRate); const d=noiseBuf.getChannelData(0);
  for(let i=0;i<n;i++) d[i]=Math.random()*2-1; return noiseBuf; }

function digFreq(t){
  if(t===STONE||t===COBBLE||t===BRICK||(t>=ORE_COAL&&t<=ORE_DIAMOND)) return 1100;
  if(t===WOOD||t===PLANK||t===SPRUCE_LOG||t===BIRCH_LOG||t===PUMPKIN||t===CACTUS) return 520;
  if(t===SAND||t===GRAVEL) return 340;
  if(t===GLASS||t===ICE) return 1700;
  if(t===LEAVES||t===SPRUCE_LEAVES||t===BIRCH_LEAVES||CROSS.has(t)) return 800;
  return 440;
}
function sfxDig(t,vol){ if(!actx)return; const now=actx.currentTime, v=vol||0.5;
  const src=actx.createBufferSource(); src.buffer=getNoise();
  const bp=actx.createBiquadFilter(); bp.type="bandpass"; bp.frequency.value=digFreq(t); bp.Q.value=0.9;
  const g=actx.createGain(); g.gain.setValueAtTime(0.0001,now);
  g.gain.exponentialRampToValueAtTime(v,now+0.005); g.gain.exponentialRampToValueAtTime(0.0001,now+0.16);
  src.connect(bp).connect(g).connect(sfxGain); src.start(now); src.stop(now+0.18); }
function sfxPlace(id){ if(!actx)return; const now=actx.currentTime;
  const o=actx.createOscillator(); o.type="square"; const base=digFreq(id)*0.4;
  o.frequency.setValueAtTime(base,now); o.frequency.exponentialRampToValueAtTime(base*0.6,now+0.09);
  const g=actx.createGain(); g.gain.setValueAtTime(0.0001,now);
  g.gain.exponentialRampToValueAtTime(0.22,now+0.005); g.gain.exponentialRampToValueAtTime(0.0001,now+0.12);
  o.connect(g).connect(sfxGain); o.start(now); o.stop(now+0.13); }
function sfxStep(){ if(!actx)return; const now=actx.currentTime;
  const src=actx.createBufferSource(); src.buffer=getNoise();
  const lp=actx.createBiquadFilter(); lp.type="lowpass"; lp.frequency.value=430;
  const g=actx.createGain(); g.gain.setValueAtTime(0.0001,now);
  g.gain.exponentialRampToValueAtTime(0.10,now+0.004); g.gain.exponentialRampToValueAtTime(0.0001,now+0.09);
  src.connect(lp).connect(g).connect(sfxGain); src.start(now); src.stop(now+0.1); }
function sfxLand(){ if(!actx)return; const now=actx.currentTime;
  const src=actx.createBufferSource(); src.buffer=getNoise();
  const lp=actx.createBiquadFilter(); lp.type="lowpass"; lp.frequency.value=300;
  const g=actx.createGain(); g.gain.setValueAtTime(0.0001,now);
  g.gain.exponentialRampToValueAtTime(0.22,now+0.004); g.gain.exponentialRampToValueAtTime(0.0001,now+0.15);
  src.connect(lp).connect(g).connect(sfxGain); src.start(now); src.stop(now+0.16); }
function sfxSplash(){ if(!actx)return; const now=actx.currentTime;
  const src=actx.createBufferSource(); src.buffer=getNoise();
  const bp=actx.createBiquadFilter(); bp.type="bandpass"; bp.frequency.setValueAtTime(900,now);
  bp.frequency.exponentialRampToValueAtTime(2400,now+0.18); bp.Q.value=0.6;
  const g=actx.createGain(); g.gain.setValueAtTime(0.0001,now);
  g.gain.exponentialRampToValueAtTime(0.28,now+0.01); g.gain.exponentialRampToValueAtTime(0.0001,now+0.32);
  src.connect(bp).connect(g).connect(sfxGain); src.start(now); src.stop(now+0.34); }
function sfxClick(){ if(!actx)return; const now=actx.currentTime;
  const o=actx.createOscillator(); o.type="triangle"; o.frequency.value=880;
  const g=actx.createGain(); g.gain.setValueAtTime(0.0001,now);
  g.gain.exponentialRampToValueAtTime(0.12,now+0.003); g.gain.exponentialRampToValueAtTime(0.0001,now+0.06);
  o.connect(g).connect(sfxGain); o.start(now); o.stop(now+0.07); }
function sfxJump(){ if(!actx)return; const now=actx.currentTime;
  const o=actx.createOscillator(); o.type="sine"; o.frequency.setValueAtTime(300,now);
  o.frequency.exponentialRampToValueAtTime(520,now+0.12);
  const g=actx.createGain(); g.gain.setValueAtTime(0.0001,now);
  g.gain.exponentialRampToValueAtTime(0.09,now+0.01); g.gain.exponentialRampToValueAtTime(0.0001,now+0.14);
  o.connect(g).connect(sfxGain); o.start(now); o.stop(now+0.15); }

/* 环境氛围音：白天鸟鸣 / 夜晚虫鸣 */
function sfxBird(){ if(!actx)return; let t=actx.currentTime; const n=2+((Math.random()*3)|0);
  for(let i=0;i<n;i++){ const o=actx.createOscillator(); o.type="sine";
    const f=2200+Math.random()*1500; o.frequency.setValueAtTime(f,t);
    o.frequency.exponentialRampToValueAtTime(f*(0.65+Math.random()*0.5),t+0.06);
    const g=actx.createGain(); g.gain.setValueAtTime(0.0001,t);
    g.gain.exponentialRampToValueAtTime(0.05,t+0.008); g.gain.exponentialRampToValueAtTime(0.0001,t+0.08);
    o.connect(g).connect(sfxGain); o.start(t); o.stop(t+0.09); t+=0.06+Math.random()*0.05; } }
function sfxCricket(){ if(!actx)return; const now=actx.currentTime;
  const o=actx.createOscillator(); o.type="square"; o.frequency.value=4500;
  const bp=actx.createBiquadFilter(); bp.type="bandpass"; bp.frequency.value=4500; bp.Q.value=10;
  const g=actx.createGain(); g.gain.value=0.0001;
  const lfo=actx.createOscillator(); lfo.type="square"; lfo.frequency.value=24;
  const lg=actx.createGain(); lg.gain.value=0.02; lfo.connect(lg).connect(g.gain);
  g.gain.setValueAtTime(0.0001,now); g.gain.linearRampToValueAtTime(0.02,now+0.03);
  g.gain.setValueAtTime(0.02,now+0.38); g.gain.exponentialRampToValueAtTime(0.0001,now+0.5);
  o.connect(bp).connect(g).connect(sfxGain); o.start(now); o.stop(now+0.52); lfo.start(now); lfo.stop(now+0.52); }
function sfxOink(){ if(!actx)return; const now=actx.currentTime;
  const o=actx.createOscillator(); o.type="sawtooth"; o.frequency.setValueAtTime(165,now);
  o.frequency.exponentialRampToValueAtTime(110,now+0.12);
  const lp=actx.createBiquadFilter(); lp.type="lowpass"; lp.frequency.value=820;
  const g=actx.createGain(); g.gain.setValueAtTime(0.0001,now);
  g.gain.exponentialRampToValueAtTime(0.10,now+0.02); g.gain.exponentialRampToValueAtTime(0.0001,now+0.2);
  o.connect(lp).connect(g).connect(sfxGain); o.start(now); o.stop(now+0.22); }
let ambTimer=0.5;
function updateAmbience(dt){
  if(!actx) return; ambTimer-=dt; if(ambTimer>0) return;
  const elev=sunDir.y;
  if(elev>0.08){ sfxBird(); ambTimer=1.6+Math.random()*4.5; }
  else if(elev<-0.05){ sfxCricket(); ambTimer=0.7+Math.random()*1.5; }
  else { ambTimer=1.2; }
}

/* 生成式环境音乐：稀疏五声音阶 + 缓慢和声垫 */
const MUS_SCALE=[0,2,4,7,9,12,14,16,19,21], MUS_ROOT=130.81; // C3 五声
const noteFreq=s=>MUS_ROOT*Math.pow(2,s/12);
function playTone(freq,dur,vel,type){ if(!actx)return; const now=actx.currentTime;
  const o=actx.createOscillator(); o.type=type||"triangle"; o.frequency.value=freq;
  const lp=actx.createBiquadFilter(); lp.type="lowpass"; lp.frequency.value=2200;
  const g=actx.createGain(); g.gain.setValueAtTime(0.0001,now);
  g.gain.linearRampToValueAtTime(vel,now+0.05); g.gain.exponentialRampToValueAtTime(0.0001,now+dur);
  o.connect(lp).connect(g).connect(musicGain); o.start(now); o.stop(now+dur+0.05); }
function scheduleMusic(){
  const s=MUS_SCALE[(Math.random()*MUS_SCALE.length)|0];
  playTone(noteFreq(s), 1.6+Math.random()*1.6, 0.10+Math.random()*0.05, "triangle");
  if(Math.random()<0.4) playTone(noteFreq(s+(Math.random()<0.5?4:7)), 2.0, 0.05, "sine");
  musicTimer=setTimeout(scheduleMusic, (0.9+Math.random()*2.4)*1000);
}
function startPad(){ [0,7,12].forEach((s,i)=>{
  const o=actx.createOscillator(); o.type="sine"; o.frequency.value=noteFreq(s)/2;
  const g=actx.createGain(); g.gain.value=0.02;
  const lfo=actx.createOscillator(); lfo.frequency.value=0.05+i*0.02;
  const lfg=actx.createGain(); lfg.gain.value=0.012;
  lfo.connect(lfg).connect(g.gain); o.connect(g).connect(musicGain); o.start(); lfo.start(); }); }
function startMusic(){ musicGain.gain.setTargetAtTime(0.5, actx.currentTime, 4.0); scheduleMusic(); startPad(); }

let stepDist=0, wasOnGround=true, wasInWater=false;
function updateAudioFeedback(dt){
  const horiz=Math.hypot(player.vel.x,player.vel.z);
