  let x=Math.floor(o.x),y=Math.floor(o.y),z=Math.floor(o.z);
  const sx=Math.sign(dir.x)||1,sy=Math.sign(dir.y)||1,sz=Math.sign(dir.z)||1;
  const initT=(o,d,c)=>d>0?(c+1-o)/d:(d<0?(c-o)/d:Infinity);
  let tMaxX=initT(o.x,dir.x,x),tMaxY=initT(o.y,dir.y,y),tMaxZ=initT(o.z,dir.z,z);
  const tdX=dir.x?Math.abs(1/dir.x):Infinity,tdY=dir.y?Math.abs(1/dir.y):Infinity,tdZ=dir.z?Math.abs(1/dir.z):Infinity;
  let nx=0,ny=0,nz=0,t=0;
  for(let i=0;i<256&&t<=maxDist;i++){
    const b=getBlock(x,y,z);
    if(b!==AIR&&b!==WATER) return {hit:true,x,y,z,nx,ny,nz};
    if(tMaxX<tMaxY&&tMaxX<tMaxZ){x+=sx;t=tMaxX;tMaxX+=tdX;nx=-sx;ny=0;nz=0;}
    else if(tMaxY<tMaxZ){y+=sy;t=tMaxY;tMaxY+=tdY;nx=0;ny=-sy;nz=0;}
    else {z+=sz;t=tMaxZ;tMaxZ+=tdZ;nx=0;ny=0;nz=-sz;}
  }
  return {hit:false};
}
function playerOverlapsVoxel(vx,vy,vz){const w=player.width/2,p=player.pos;
  return aabbHitsVoxel(p.x-w,p.y,p.z-w,p.x+w,p.y+player.height,p.z+w,vx,vy,vz);}

// 可下落方块：挖掉下方时上方整体塌落
function settleFalling(x,y,z){ let writeY=y;
  for(let yy=y+1; yy<WY; yy++){ const t=getBlock(x,yy,z);
    if(FALLING.has(t)){ setRaw(x,yy,z,AIR); setRaw(x,writeY,z,t); writeY++; } else break; } }
// 放下的可下落方块下坠到落点
function dropFalling(x,y,z){ const t=getBlock(x,y,z); let yy=y;
  while(yy>0){ const below=getBlock(x,yy-1,z); if(below===AIR||CROSS.has(below)) yy--; else break; }
  if(yy!==y){ setRaw(x,y,z,AIR); setRaw(x,yy,z,t); } }

// 移除失去支撑的十字植物（花/草/枯木丛），修复挖掉下方后植物悬空
function fixColumnPlants(x,z){ for(let yy=1; yy<WY; yy++){ const p=getBlock(x,yy,z);
    if(CROSS.has(p) && getBlock(x,yy-1,z)===AIR) setRaw(x,yy,z,AIR); } }

function breakAt(x,y,z){ if(y<=0)return; const t=getBlock(x,y,z); if(t===AIR||t===WATER)return;
  setRaw(x,y,z,AIR); settleFalling(x,y,z); fixColumnPlants(x,z); rebuildAround(x,y,z);
  sfxDig(t); }

// 挖掘进度（按方块硬度需要持续按住）
const mining={x:0,y:0,z:0,active:false,progress:0,total:1,tick:0};
function resetMining(){ mining.active=false; mining.progress=0; updateMineRing(0); crackMesh.visible=false; }
function updateMining(dt){
  if(!mouseBtn.left){ if(mining.active)resetMining(); return; }
  const r=raycastVoxel(6);
  if(!r.hit || r.y<=0){ if(mining.active)resetMining(); return; }
  if(!mining.active || r.x!==mining.x || r.y!==mining.y || r.z!==mining.z){
    mining.active=true; mining.x=r.x; mining.y=r.y; mining.z=r.z; mining.progress=0; mining.tick=0;
    mining.total=hardnessOf(getBlock(r.x,r.y,r.z)); }
  mining.progress+=dt;
  mining.tick-=dt; if(mining.tick<=0){ sfxDig(getBlock(mining.x,mining.y,mining.z),0.22); mining.tick=0.22; }
  // 裂纹叠加（十字植物不显示）
  const tb=getBlock(mining.x,mining.y,mining.z);
  if(!CROSS.has(tb)){ const stage=Math.min(9,Math.floor(mining.progress/mining.total*10));
    crackTex.offset.x=stage/10; crackMesh.position.set(mining.x+0.5,mining.y+0.5,mining.z+0.5); crackMesh.visible=true; }
  else crackMesh.visible=false;
  if(mining.progress>=mining.total){ breakAt(mining.x,mining.y,mining.z); resetMining(); }
  else updateMineRing(mining.progress/mining.total);
}

function placeBlock(){const r=raycastVoxel(6);if(!r.hit)return;
  const x=r.x+r.nx,y=r.y+r.ny,z=r.z+r.nz; if(!inBounds(x,y,z))return;
  const c=getBlock(x,y,z); if(c!==AIR&&c!==WATER)return; if(playerOverlapsVoxel(x,y,z))return;
  const id=HOTBAR[selected].id; setRaw(x,y,z,id);
