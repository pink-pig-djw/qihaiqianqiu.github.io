const hudEl=document.getElementById("hud"), clockEl=document.getElementById("clock");
let fpsT=0,fpsN=0,fps=0;
function biomeNameAt(x,z){ const info=columnInfo(x,z);
  if(info.topY<SEA) return "海洋";
  if(info.topY<=SEA+1 && info.biome!==DESERT && info.biome!==SNOWY) return "海滩";
  return BIOME_NAME[info.biome]; }
function fmtClock(){ const hh=(timeOfDay*24+6)%24; const h=Math.floor(hh), m=Math.floor((hh-h)*60);
  return (h<10?"0":"")+h+":"+(m<10?"0":"")+m; }
function dayPhaseLabel(){ const e=sunDir.y;
  if(e>0.22) return "白天"; if(e<-0.06) return "夜晚";
  return timeOfDay<0.5?"黎明":"黄昏"; }
function updateHUD(dt){
  fpsT+=dt;fpsN++; if(fpsT>=0.5){fps=Math.round(fpsN/fpsT);fpsT=0;fpsN=0;}
  const p=player.pos;
  hudEl.innerHTML =
    "坐标 X <b>"+p.x.toFixed(1)+"</b> Y <b>"+p.y.toFixed(1)+"</b> Z <b>"+p.z.toFixed(1)+"</b><br>"+
    "群系 <b>"+biomeNameAt(Math.floor(p.x),Math.floor(p.z))+"</b> · 手持 <b>"+HOTBAR[selected].name+"</b> · "+fps+" FPS";
  const orb=skyUniforms.sunColor.value;
  clockEl.innerHTML='<span class="orb" style="background:#'+orb.getHexString()+'"></span>'+fmtClock()+" · "+dayPhaseLabel()+(fastTime?" ⏩":"");
}

/* ----------------------------- 简单生物（小猪） ------------------------------ */
const TAU=Math.PI*2;
const mobMats={ body:new THREE.MeshBasicMaterial({color:0xe89a9a}), snout:new THREE.MeshBasicMaterial({color:0xcf7d7d}),
  leg:new THREE.MeshBasicMaterial({color:0xdd8d8d}), eye:new THREE.MeshBasicMaterial({color:0x241a1a}) };
const mobBase={ body:new THREE.Color(0xe89a9a), snout:new THREE.Color(0xcf7d7d), leg:new THREE.Color(0xdd8d8d) };
function makePig(){
  const g=new THREE.Group();
  const box=(w,h,d,mat,x,y,z)=>{ const m=new THREE.Mesh(new THREE.BoxGeometry(w,h,d),mat); m.position.set(x,y,z); g.add(m); return m; };
  box(0.95,0.6,0.55, mobMats.body, 0,0.55,0);                 // 身体
  box(0.5,0.5,0.5,  mobMats.body, 0.62,0.6,0);                // 头
  box(0.2,0.18,0.14, mobMats.snout, 0.9,0.5,0);               // 鼻子
  box(0.07,0.07,0.07, mobMats.eye, 0.8,0.72,0.17);
  box(0.07,0.07,0.07, mobMats.eye, 0.8,0.72,-0.17);
  const legs=[]; const lp=[[0.32,-0.17],[0.32,0.17],[-0.32,-0.17],[-0.32,0.17]];
  for(const [lx,lz] of lp){ const geo=new THREE.BoxGeometry(0.18,0.42,0.18); geo.translate(0,-0.21,0);
    const m=new THREE.Mesh(geo,mobMats.leg); m.position.set(lx,0.42,lz); g.add(m); legs.push(m); }
  return {group:g, legs};
}
const mobs=[];
function surfaceY(x,z,fromY){ const xi=Math.floor(x),zi=Math.floor(z), top=Math.min(WY-1,Math.floor(fromY)+2);
  for(let y=top;y>=0;y--){ if(isSolidBlock(getBlock(xi,y,zi))) return y+1; } return null; }
function relocateMob(m){
  for(let k=0;k<24;k++){ const a=Math.random()*TAU, d=16+Math.random()*32;
    const x=player.pos.x+Math.cos(a)*d, z=player.pos.z+Math.sin(a)*d;
    if(x<3||z<3||x>WX-3||z>WZ-3) continue;
    const gy=surfaceY(x,z,WY-2); if(gy===null||gy<SEA) continue;
    if(getBlock(Math.floor(x),gy,Math.floor(z))===WATER) continue;
    m.pos.set(x,gy,z); m.dir=Math.random()*TAU; return; } }
function spawnMobs(n){ for(let i=0;i<n;i++){ const pig=makePig();
    pig.pos=new THREE.Vector3(); pig.dir=Math.random()*TAU; pig.speed=1.25; pig.turnT=Math.random()*2;
    pig.phase=0; pig.moving=true; pig.oinkT=6+Math.random()*12;
    scene.add(pig.group); mobs.push(pig); relocateMob(pig); } }
function updateMobs(dt){
  const lc=opaqueMat.color;
  mobMats.body.color.setRGB(mobBase.body.r*lc.r, mobBase.body.g*lc.g, mobBase.body.b*lc.b);
  mobMats.snout.color.setRGB(mobBase.snout.r*lc.r, mobBase.snout.g*lc.g, mobBase.snout.b*lc.b);
  mobMats.leg.color.setRGB(mobBase.leg.r*lc.r, mobBase.leg.g*lc.g, mobBase.leg.b*lc.b);
  for(const m of mobs){
    m.turnT-=dt;
    if(m.turnT<=0){ m.dir+=(Math.random()*2-1)*1.1; m.turnT=1.5+Math.random()*2.6; if(Math.random()<0.3) m.moving=!m.moving; }
    let moved=false;
    if(m.moving){ const nx=m.pos.x+Math.cos(m.dir)*m.speed*dt, nz=m.pos.z+Math.sin(m.dir)*m.speed*dt;
      const gy=surfaceY(nx,nz,m.pos.y);
      if(gy!==null && Math.abs(gy-m.pos.y)<=1.2 && getBlock(Math.floor(nx),gy,Math.floor(nz))!==WATER && gy>=SEA){
        m.pos.x=nx; m.pos.z=nz; m.pos.y=gy; moved=true; }
      else m.dir+=2.1; }
    m.phase += dt*(moved?9:0);
    for(let i=0;i<m.legs.length;i++) m.legs[i].rotation.z = moved?Math.sin(m.phase+((i===0||i===3)?0:Math.PI))*0.5:0;
    m.group.position.set(m.pos.x,m.pos.y,m.pos.z);
    m.group.rotation.y = -m.dir;
    const dx=m.pos.x-player.pos.x, dz=m.pos.z-player.pos.z;
    if(dx*dx+dz*dz > 78*78) relocateMob(m);
    m.oinkT-=dt; if(m.oinkT<=0){ m.oinkT=9+Math.random()*16; if(dx*dx+dz*dz<36*36 && Math.random()<0.5) sfxOink(); }
  }
}

/* ----------------------------- 主循环 ------------------------------ */
let last=performance.now();
function loop(now){
  requestAnimationFrame(loop);
  let dt=(now-last)/1000; last=now; if(dt>0.05)dt=0.05;

  if(active){
    updatePhysics(dt);
    updateMining(dt);
    actCooldown-=dt;
    if(actCooldown<=0 && mouseBtn.right){ placeBlock(); actCooldown=0.18; }
    updateAudioFeedback(dt);
    updateAmbience(dt);
    updateMobs(dt);
  } else if(mining.active){ resetMining(); }

  updateStreaming(false);
  processBuildQueue(isTouch?1:2);
  updateSky(dt);

  const r=raycastVoxel(6);
  if(active&&r.hit){highlight.visible=true;highlight.position.set(r.x+0.5,r.y+0.5,r.z+0.5);}
  else highlight.visible=false;

  updateHUD(dt);
  renderer.render(scene,camera);
}

/* ----------------------------- 启动 ------------------------------ */
function init(){
  buildMaterials();
  genWorld();
  spawnPlayer();
  buildHotbar();
  const initRD=Math.min(RENDER_DIST,5);
  updateStreaming(true);
  processBuildQueue((2*initRD+1)*(2*initRD+1));   // 预先建好出生区，其余随移动流式加载
  spawnMobs(6);
  camera.position.set(player.pos.x,player.pos.y+player.eye,player.pos.z);
  camera.rotation.set(pitch,yaw,0,"YXZ");
  updateSky(0);
  document.getElementById("loading").style.display="none";
  requestAnimationFrame(loop);
}
requestAnimationFrame(()=>setTimeout(init,30));
</script>
